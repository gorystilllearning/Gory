[Desktop Entry]
Type=Application
Name=Move KDE Panel to Top
Exec=sh -c 'sleep 3 && dbus-send --session --dest=org.kde.plasmashell --type=method_call /PlasmaShell org.kde.PlasmaShell.evaluateScript string:"var panels = panels(); if (panels.length > 0) { panels[0].location = \"top\"; panels[0].height = 28; }" && rm -f ~/.config/autostart/move-panel.desktop'
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
X-KDE-autostart-after=panel
